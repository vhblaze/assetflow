generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  name       String?
  portfolios Portfolio[]
  auditLogs  AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Portfolio {
  id     String @id @default(uuid())
  name   String
  userId String

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings      Holding[]
  contributions Contribution[]
  dailyMetrics  DailyMetric[]
  insights      Insight[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Asset {
  id       String  @id @default(uuid())
  symbol   String
  name     String?
  currency String  @default("BRL")

  holdings Holding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([symbol, currency])
}

model Holding {
  id          String @id @default(uuid())
  portfolioId String
  assetId     String

  quantity Decimal @db.Decimal(20, 8)
  avgPrice Decimal @db.Decimal(20, 8)

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset     Asset     @relation(fields: [assetId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([portfolioId, assetId])
  @@index([portfolioId])
  @@index([assetId])
}

model Contribution {
  id          String   @id @default(uuid())
  portfolioId String
  date        DateTime
  amount      Decimal  @db.Decimal(20, 2)
  note        String?

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([portfolioId, date])
}

model DailyMetric {
  id          String   @id @default(uuid())
  portfolioId String
  date        DateTime

  portfolioValue            Decimal @db.Decimal(20, 2)
  dailyReturnPct            Decimal @db.Decimal(10, 4)
  weeklyReturnPct           Decimal @db.Decimal(10, 4)
  volatility7dPct           Decimal @db.Decimal(10, 4)
  maxDrawdown30dPct         Decimal @db.Decimal(10, 4)
  concentrationTop1Pct      Decimal @db.Decimal(10, 4)
  concentrationTop3Pct      Decimal @db.Decimal(10, 4)
  contributionToday         Decimal @db.Decimal(20, 2)
  daysSinceLastContribution Int

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([portfolioId, date])
  @@index([portfolioId, date])
}

model Insight {
  id          String   @id @default(uuid())
  portfolioId String
  date        DateTime

  headline   String
  message    String
  tags       String[]
  confidence Decimal  @db.Decimal(3, 2)
  disclaimer String

  rawPayload  Json?
  rawResponse Json?

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([portfolioId, date])
  @@index([portfolioId, date])
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  GENERATE_INSIGHT
}

model AuditLog {
  id       String      @id @default(uuid())
  userId   String?
  action   AuditAction
  entity   String?
  entityId String?
  metadata Json?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
